{
  "openapi": "3.1.0",
  "info": {
    "title": "Codex Bridge API",
    "version": "0.0.1",
    "description": "Local HTTP API exposed by the Codex Bridge VS Code extension."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8765"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Get bridge health",
        "responses": {
          "200": {
            "description": "Bridge health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs": {
      "get": {
        "summary": "List jobs",
        "responses": {
          "200": {
            "description": "Jobs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "summary": "Get one job",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversations/open": {
      "get": {
        "summary": "List open Codex conversations",
        "responses": {
          "200": {
            "description": "Open conversations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenConversationsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversations/current": {
      "get": {
        "summary": "Get the active conversation",
        "responses": {
          "200": {
            "description": "Current conversation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentConversationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversations": {
      "post": {
        "summary": "Create a new conversation or draft",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateConversationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversations/current/messages": {
      "post": {
        "summary": "Send a message to the active conversation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversationMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message dispatched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversations/{conversationId}/messages": {
      "post": {
        "summary": "Continue a specific conversation",
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversationMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message dispatched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationMessageResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Job": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "starting",
              "running",
              "completed",
              "failed"
            ]
          },
          "operation": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "startedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "completedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "pid": {
            "type": [
              "integer",
              "null"
            ]
          },
          "conversationId": {
            "type": [
              "string",
              "null"
            ]
          },
          "opened": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "openError": {
            "type": [
              "string",
              "null"
            ]
          },
          "eventCount": {
            "type": "integer"
          },
          "lastEventType": {
            "type": [
              "string",
              "null"
            ]
          },
          "exitCode": {
            "type": [
              "integer",
              "null"
            ]
          },
          "signal": {
            "type": [
              "string",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      },
      "DispatchOptions": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "approvalPolicy": {
            "type": "string",
            "enum": [
              "untrusted",
              "on-failure",
              "on-request",
              "never"
            ]
          },
          "sandbox": {
            "type": "string",
            "enum": [
              "read-only",
              "workspace-write",
              "danger-full-access"
            ]
          },
          "dangerouslyBypassApprovalsAndSandbox": {
            "type": "boolean"
          },
          "model": {
            "type": "string"
          },
          "serviceTier": {
            "type": "string",
            "enum": [
              "fast",
              "flex"
            ]
          },
          "baseInstructions": {
            "type": "string"
          },
          "developerInstructions": {
            "type": "string"
          },
          "personality": {
            "type": "string",
            "enum": [
              "none",
              "friendly",
              "pragmatic"
            ]
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sendTimeoutMs": {
            "type": "integer"
          },
          "timeoutMs": {
            "type": "integer"
          },
          "openTimeoutMs": {
            "type": "integer"
          },
          "outputSchemaPath": {
            "type": "string"
          },
          "outputLastMessagePath": {
            "type": "string"
          },
          "ensureOpen": {
            "type": "boolean"
          },
          "upgradeLegacyExecConversations": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "status": {
            "type": "object",
            "properties": {
              "running": {
                "type": "boolean"
              },
              "url": {
                "type": "string"
              },
              "currentConversationId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "jobs": {
                "type": "object",
                "properties": {
                  "total": {
                    "type": "integer"
                  },
                  "starting": {
                    "type": "integer"
                  },
                  "running": {
                    "type": "integer"
                  },
                  "completed": {
                    "type": "integer"
                  },
                  "failed": {
                    "type": "integer"
                  },
                  "latestJobId": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          },
          "openConversations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conversation"
            }
          }
        }
      },
      "JobsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "JobResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "job": {
            "$ref": "#/components/schemas/Job"
          }
        }
      },
      "OpenConversationsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "conversations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conversation"
            }
          }
        }
      },
      "CurrentConversationResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "conversation": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Conversation"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "CreateConversationRequest": {
        "$ref": "#/components/schemas/DispatchOptions"
      },
      "ConversationMessageRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/DispatchOptions"
          },
          {
            "type": "object",
            "required": [
              "message"
            ]
          }
        ]
      },
      "CreateConversationResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "conversationId": {
            "type": [
              "string",
              "null"
            ]
          },
          "sent": {
            "type": "boolean"
          },
          "draft": {
            "type": "boolean"
          },
          "jobUrl": {
            "type": [
              "string",
              "null"
            ]
          },
          "job": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Job"
              },
              {
                "type": "null"
              }
            ]
          },
          "opened": {
            "type": "boolean"
          },
          "openError": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      },
      "ConversationMessageResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "conversationId": {
            "type": "string"
          },
          "sent": {
            "type": "boolean"
          },
          "jobUrl": {
            "type": "string"
          },
          "job": {
            "$ref": "#/components/schemas/Job"
          },
          "opened": {
            "type": "boolean"
          },
          "openError": {
            "type": [
              "string",
              "null"
            ]
          },
          "requestedConversationId": {
            "type": [
              "string",
              "null"
            ]
          },
          "upgradedFromConversationId": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  }
}
